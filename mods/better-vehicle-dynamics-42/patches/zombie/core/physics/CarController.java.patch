+   // one profile family (e.g. "ModernTire2" -> "ModernTire"). Returns the
+   // input unchanged when it has no trailing digits or is null/empty.
+   private static String tireFamilyKey(String itemType) {
+      if (itemType == null) {
+         return "";
+      }
+      int end = itemType.length();
+      while (end > 0 && itemType.charAt(end - 1) >= '0' && itemType.charAt(end - 1) <= '9') {
+         end--;
+      }
+      return end == itemType.length() ? itemType : itemType.substring(0, end);
+   }
