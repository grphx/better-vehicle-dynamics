+   // Read a numeric field from a Kahlua row, falling back to a caller-chosen
+   // default when the row is null or the field is absent / non-numeric.
+   // KahluaTableImpl.rawgetFloat returns -1 for a missing key, which would be
+   // a real (catastrophic) grip multiplier here, so the lookup is explicit.
+   private static float bridgeFieldOr(KahluaTableImpl row, String field, float fallback) {
+      if (row == null) {
+         return fallback;
+      }
+      Object v = row.rawget(field);
+      if (v instanceof Double d) {
+         return d.floatValue();
+      }
+      if (v instanceof Float f) {
+         return f;
+      }
+      return fallback;
+   }
