+   private SandboxOption resolveSandboxOption(String key) {
+      SandboxOption cached = this.sandboxHandleCache.get(key);
+      if (cached != null) {
+         return cached;
+      }
+      if (this.sandboxHandleMisses.contains(key)) {
+         return null;
+      }
+      SandboxOption opt = SandboxOptions.instance.getOptionByName(key);
+      if (opt == null) {
+         this.sandboxHandleMisses.add(key);
+         return null;
+      }
+      this.sandboxHandleCache.put(key, opt);
+      return opt;
+   }
