+   private float getSandboxOption(String key, float fallback) {
+      SandboxOption opt = this.resolveSandboxOption(key);
+      if (opt == null) {
+         return fallback;
+      }
+      String raw = opt.asConfigOption().getValueAsString();
+      float parsed;
+      try {
+         parsed = (float)Double.parseDouble(raw);
+      } catch (NumberFormatException nfe) {
+         DebugLog.log("[BetterVehicleDynamics] sandbox key " + key + " not numeric ('" + raw + "'); using " + fallback);
+         return fallback;
+      }
+      if (Float.isNaN(parsed)) {
+         DebugLog.log("[BetterVehicleDynamics] sandbox key " + key + " was NaN; using " + fallback);
+         return fallback;
+      }
+      return parsed;
+   }
